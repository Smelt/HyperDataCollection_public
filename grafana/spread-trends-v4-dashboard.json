        {
          "datasource": {
            "type": "mysql",
            "uid": "ef1n1ggi71xq8d"
          },
          "editorMode": "code",
          "format": "time_series",
          "rawQuery": true,
          "rawSql": "  WITH top_pairs AS (\n    SELECT pair\n    FROM spread_snapshots_partitioned\n    WHERE timestamp >= UNIX_TIMESTAMP($__timeFrom()) * 1000\n      AND timestamp <= UNIX_TIMESTAMP($__timeTo()) * 1000\n    GROUP BY pair\n    ORDER BY AVG(spread_bps) DESC\n    LIMIT 6\n  )\n  SELECT\n    FROM_UNIXTIME(FLOOR(s.timestamp/1000/60)*60) as time,\n    s.pair,\n    AVG(s.spread_bps) as value\n  FROM spread_snapshots_partitioned s\n  INNER JOIN top_pairs t ON s.pair = t.pair\n  WHERE s.timestamp >= UNIX_TIMESTAMP($__timeFrom()) * 1000\n    AND s.timestamp <= UNIX_TIMESTAMP($__timeTo()) * 1000\n  GROUP BY FLOOR(s.timestamp/1000/60), s.pair\n  ORDER BY time",
          "refId": "A",
          "sql": {
            "columns": [
              {
                "parameters": [],
                "type": "function"
              }
            ],
            "groupBy": [
              {
                "property": {
                  "type": "string"
                },
                "type": "groupBy"
              }
            ],
            "limit": 50
          }
        }
      ],
      "title": "Spreads over time",
      "type": "timeseries"
