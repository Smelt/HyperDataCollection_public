          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT\n  pair as Pair,\n  ROUND(AVG(spread_bps), 2) as Average,\n  ROUND(MIN(spread_bps), 2) as Minimum,\n  ROUND(MAX(spread_bps), 2) as Maximum,\n  ROUND(STDDEV(spread_bps), 2) as StdDev,\n  COUNT(*) as Samples\nFROM spread_snapshots_partitioned\nWHERE timestamp >= UNIX_TIMESTAMP($__timeFrom()) * 1000\n  AND timestamp <= UNIX_TIMESTAMP($__timeTo()) * 1000\nGROUP BY pair\nHAVING COUNT(*) > 10\nORDER BY Average DESC\nLIMIT 15",
          "refId": "A",
