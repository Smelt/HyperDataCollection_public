            "type": "mysql",
            "uid": "ef1n1ggi71xq8d"
          },
          "format": "time_series",
          "rawSql": "SELECT FLOOR(s.timestamp/1000) as time_sec, s.pair, s.spread_pct as value FROM spread_snapshots s INNER JOIN (SELECT pair FROM spread_snapshots_1min WHERE timestamp >= $__timeFrom() AND timestamp <= $__timeTo() GROUP BY pair ORDER BY AVG(avg_spread_bps) DESC LIMIT 10) top_pairs ON s.pair = top_pairs.pair WHERE s.timestamp >= $__timeFrom() AND timestamp <= $__timeTo() ORDER BY time_sec",
          "refId": "A"
        }
