          },
          "format": "table",
          "rawSql": "SELECT pair as 'Pair', ROUND(AVG(avg_spread_bps), 2) as 'Avg Spread (bps)', ROUND(AVG(avg_spread_bps) - 3.0, 2) as 'Profit After Fees (bps)', ROUND(MIN(spread_bps), 2) as 'Min (bps)', ROUND(MAX(spread_bps), 2) as 'Max (bps)', COUNT(*) as 'Samples' FROM spread_snapshots_1min WHERE timestamp >= $__timeFrom() AND timestamp <= $__timeTo() GROUP BY pair HAVING AVG(avg_spread_bps) > 3.0 ORDER BY `Profit After Fees (bps)` DESC LIMIT 20",
          "refId": "A"
        }
      ],
