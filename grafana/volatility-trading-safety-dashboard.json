          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT\n  pair as 'Pair',\n  ROUND(avg_spread_bps, 2) as 'Avg Spread (bps)',\n  ROUND(stddev_spread_bps, 2) as 'Spread StdDev',\n  ROUND(avg_spread_bps / NULLIF(stddev_spread_bps, 0), 2) as 'Spread/Vol Ratio',\n  CASE\n    WHEN avg_spread_bps / NULLIF(stddev_spread_bps, 0) >= 2.0 THEN 'IDEAL'\n    WHEN avg_spread_bps / NULLIF(stddev_spread_bps, 0) >= 1.0 THEN 'FAVORABLE'\n    ELSE 'CHOPPY'\n  END as 'Trading Status'\nFROM spread_stats_hourly\nWHERE hour >= DATE_SUB(NOW(), INTERVAL 1 HOUR)\nGROUP BY pair\nORDER BY avg_spread_bps DESC\nLIMIT 20",
          "refId": "A"
        }
      ],
      "title": "Spread-to-Volatility Ratio by Pair (Last 1 Hour)",
