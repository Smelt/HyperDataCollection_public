          "editorMode": "code",
          "format": "time_series",
          "rawQuery": true,
          "rawSql": "SELECT\n  FROM_UNIXTIME(FLOOR(s.timestamp/1000/300)*300) as time,\n  s.pair,\n  AVG(s.spread_bps) as value\nFROM spread_snapshots_partitioned s\nWHERE s.timestamp >= UNIX_TIMESTAMP(NOW() - INTERVAL 6 HOUR) * 1000\n  AND s.pair IN (\n    SELECT pair FROM spread_stats_hourly \n    WHERE hour >= DATE_SUB(NOW(), INTERVAL 24 HOUR)\n    GROUP BY pair ORDER BY AVG(avg_spread_bps) DESC LIMIT 6\n  )\nGROUP BY FLOOR(s.timestamp/1000/300), s.pair\nORDER BY time",
          "refId": "A"
        }
      ],
      "title": "Top Pairs - Spread Over Time (5-min avg)",
      "type": "timeseries"
    },
