          "rawSql": "SELECT\n  FROM_UNIXTIME(timestamp/1000) as 'Time',\n  ROUND(dvol, 1) as 'DVOL %',\n  ROUND(short_term_iv, 1) as 'Short IV %',\n  ROUND(expected_daily_move_pct, 2) as 'Daily Move %',\n  risk_reason as 'Risk Reason'\nFROM btc_implied_volatility\nWHERE elevated_risk = 1\n  AND timestamp >= UNIX_TIMESTAMP($__timeFrom()) * 1000\n  AND timestamp <= UNIX_TIMESTAMP($__timeTo()) * 1000\nORDER BY timestamp DESC\nLIMIT 50",
