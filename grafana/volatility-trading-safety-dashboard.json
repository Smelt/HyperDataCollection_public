          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT\n  'DVOL (30-Day IV)' as Metric,\n  ROUND(AVG(dvol), 2) as Average,\n  ROUND(MIN(dvol), 2) as Minimum,\n  ROUND(MAX(dvol), 2) as Maximum,\n  ROUND(STDDEV(dvol), 2) as StdDev\nFROM btc_implied_volatility\nWHERE timestamp >= UNIX_TIMESTAMP($__timeFrom()) * 1000\n  AND timestamp <= UNIX_TIMESTAMP($__timeTo()) * 1000\n\nUNION ALL\n\nSELECT\n  'Short-Term IV' as Metric,\n  ROUND(AVG(short_term_iv), 2) as Average,\n  ROUND(MIN(short_term_iv), 2) as Minimum,\n  ROUND(MAX(short_term_iv), 2) as Maximum,\n  ROUND(STDDEV(short_term_iv), 2) as StdDev\nFROM btc_implied_volatility\nWHERE timestamp >= UNIX_TIMESTAMP($__timeFrom()) * 1000\n  AND timestamp <= UNIX_TIMESTAMP($__timeTo()) * 1000\n\nUNION ALL\n\nSELECT\n  'Expected Daily Move %' as Metric,\n  ROUND(AVG(expected_daily_move_pct), 2) as Average,\n  ROUND(MIN(expected_daily_move_pct), 2) as Minimum,\n  ROUND(MAX(expected_daily_move_pct), 2) as Maximum,\n  ROUND(STDDEV(expected_daily_move_pct), 2) as StdDev\nFROM btc_implied_volatility\nWHERE timestamp >= UNIX_TIMESTAMP($__timeFrom()) * 1000\n  AND timestamp <= UNIX_TIMESTAMP($__timeTo()) * 1000",
          "refId": "A"
        }
      ],
