          "rawQuery": true,
          "rawSql": "WITH position_pairs AS (\n  SELECT\n    coin,\n    time as close_time,\n    closed_pnl,\n    dir,\n    LAG(time) OVER (PARTITION BY coin ORDER BY time) as open_time,\n    LAG(dir) OVER (PARTITION BY coin ORDER BY time) as prev_dir,\n    (time - LAG(time) OVER (PARTITION BY coin ORDER BY time)) / 1000 as hold_duration_seconds\n  FROM user_trades\n  WHERE time >= UNIX_TIMESTAMP($__timeFrom()) * 1000\n    AND time <= UNIX_TIMESTAMP($__timeTo()) * 1000\n),\nclosed_positions AS (\n  SELECT\n    hold_duration_seconds,\n    closed_pnl\n  FROM position_pairs\n  WHERE dir LIKE 'Close%'\n    AND prev_dir LIKE 'Open%'\n    AND hold_duration_seconds IS NOT NULL\n    AND hold_duration_seconds > 0\n),\nduration_percentiles AS (\n  SELECT\n    hold_duration_seconds,\n    closed_pnl,\n    CASE\n      WHEN PERCENT_RANK() OVER (ORDER BY hold_duration_seconds) < 0.10 THEN 'P0-10 (Fast)'\n      WHEN PERCENT_RANK() OVER (ORDER BY hold_duration_seconds) < 0.25 THEN 'P10-25'\n      WHEN PERCENT_RANK() OVER (ORDER BY hold_duration_seconds) < 0.50 THEN 'P25-50'\n      WHEN PERCENT_RANK() OVER (ORDER BY hold_duration_seconds) < 0.75 THEN 'P50-75'\n      WHEN PERCENT_RANK() OVER (ORDER BY hold_duration_seconds) < 0.90 THEN 'P75-90'\n      ELSE 'P90-100 (Slow)'\n    END as percentile_bucket\n  FROM closed_positions\n)\nSELECT\n  percentile_bucket as Percentile,\n  AVG(closed_pnl) as \"Avg Profit\",\n  COUNT(*) as Positions\nFROM duration_percentiles\nGROUP BY percentile_bucket\nORDER BY\n  CASE percentile_bucket\n    WHEN 'P0-10 (Fast)' THEN 1\n    WHEN 'P10-25' THEN 2\n    WHEN 'P25-50' THEN 3\n    WHEN 'P50-75' THEN 4\n    WHEN 'P75-90' THEN 5\n    WHEN 'P90-100 (Slow)' THEN 6\n  END",
          "refId": "A"
        }
      ],
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Positions": false
            },
            "indexByName": {
              "Avg Profit": 1,
              "Percentile": 0,
              "Positions": 2
            },
            "renameByName": {}
          }
        }
      ]
    }
  ],
