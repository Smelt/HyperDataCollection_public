          "rawQuery": true,
          "rawSql": "SELECT\n  FROM_UNIXTIME(FLOOR(time/1000/$window_seconds)*$window_seconds) as time,\n  coin as metric,\n  AVG(closed_pnl) as value\nFROM user_trades\nWHERE time >= UNIX_TIMESTAMP($__timeFrom()) * 1000\n  AND time <= UNIX_TIMESTAMP($__timeTo()) * 1000\nGROUP BY FLOOR(time/1000/$window_seconds), coin\nORDER BY time",
