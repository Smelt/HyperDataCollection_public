          "rawSql": "WITH traded_coins AS (\n  SELECT DISTINCT coin COLLATE utf8mb4_0900_ai_ci as pair\n  FROM user_trades\n  WHERE time >= UNIX_TIMESTAMP($__timeFrom()) * 1000\n    AND time <= UNIX_TIMESTAMP($__timeTo()) * 1000\n)\nSELECT\n  FROM_UNIXTIME(FLOOR(s.timestamp/1000/$window_seconds)*$window_seconds) as time,\n  s.pair as metric,\n  STDDEV((s.best_bid + s.best_ask) / 2) as value\nFROM spread_snapshots s\nINNER JOIN traded_coins tc ON s.pair = tc.pair\nWHERE s.timestamp >= UNIX_TIMESTAMP($__timeFrom()) * 1000\n  AND s.timestamp <= UNIX_TIMESTAMP($__timeTo()) * 1000\nGROUP BY FLOOR(s.timestamp/1000/$window_seconds), s.pair\nHAVING COUNT(*) >= 2\nORDER BY time",
