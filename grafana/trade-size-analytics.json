      "targets": [
        {
          "editorMode": "code",
          "format": "time_series",
          "rawQuery": true,
          "rawSql": "WITH time_buckets AS (\n  SELECT \n    FLOOR(timestamp/1000/$window_seconds)*$window_seconds as time_bucket,\n    notional_usd,\n    PERCENT_RANK() OVER (PARTITION BY FLOOR(timestamp/1000/$window_seconds) ORDER BY notional_usd) as pct_rank\n  FROM trade_sizes\n  WHERE timestamp >= UNIX_TIMESTAMP($__timeFrom()) * 1000 AND timestamp <= UNIX_TIMESTAMP($__timeTo()) * 1000\n    AND ('${pair:raw}' = '$__all' OR pair IN (${pair:sqlstring}))\n)\nSELECT \n  FROM_UNIXTIME(time_bucket) as time,\n  'P25' as metric,\n  ROUND(MIN(CASE WHEN pct_rank >= 0.25 THEN notional_usd END), 2) as value\nFROM time_buckets\nGROUP BY time_bucket\nUNION ALL\nSELECT \n  FROM_UNIXTIME(time_bucket) as time,\n  'P50' as metric,\n  ROUND(MIN(CASE WHEN pct_rank >= 0.50 THEN notional_usd END), 2) as value\nFROM time_buckets\nGROUP BY time_bucket\nUNION ALL\nSELECT \n  FROM_UNIXTIME(time_bucket) as time,\n  'P75' as metric,\n  ROUND(MIN(CASE WHEN pct_rank >= 0.75 THEN notional_usd END), 2) as value\nFROM time_buckets\nGROUP BY time_bucket\nORDER BY time, metric",
          "refId": "A"
        }
      ],
