      "targets": [
        {
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "WITH ranked AS (\n  SELECT \n    pair,\n    notional_usd,\n    PERCENT_RANK() OVER (PARTITION BY pair ORDER BY notional_usd) as pct_rank\n  FROM trade_sizes\n  WHERE timestamp >= UNIX_TIMESTAMP($__timeFrom()) * 1000 AND timestamp <= UNIX_TIMESTAMP($__timeTo()) * 1000\n    AND ('${pair:raw}' = '$__all' OR pair IN (${pair:sqlstring}))\n)\nSELECT \n  pair as Currency,\n  COUNT(*) as Trades,\n  ROUND(MIN(CASE WHEN pct_rank >= 0.25 THEN notional_usd END), 2) as P25,\n  ROUND(MIN(CASE WHEN pct_rank >= 0.50 THEN notional_usd END), 2) as P50,\n  ROUND(MIN(CASE WHEN pct_rank >= 0.75 THEN notional_usd END), 2) as P75\nFROM ranked\nGROUP BY pair\nORDER BY Trades DESC",
          "refId": "A"
        }
      ],
      "title": "Percentiles by Currency",
      "type": "table"
    },
