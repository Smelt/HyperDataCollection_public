      "targets": [
        {
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "WITH ranked AS (\n  SELECT \n    pair,\n    notional_usd,\n    CASE \n      WHEN PERCENT_RANK() OVER (PARTITION BY pair ORDER BY notional_usd) < 0.10 THEN 'P0-10'\n      WHEN PERCENT_RANK() OVER (PARTITION BY pair ORDER BY notional_usd) < 0.25 THEN 'P10-25'\n      WHEN PERCENT_RANK() OVER (PARTITION BY pair ORDER BY notional_usd) < 0.50 THEN 'P25-50'\n      WHEN PERCENT_RANK() OVER (PARTITION BY pair ORDER BY notional_usd) < 0.75 THEN 'P50-75'\n      WHEN PERCENT_RANK() OVER (PARTITION BY pair ORDER BY notional_usd) < 0.90 THEN 'P75-90'\n      ELSE 'P90-100'\n    END as percentile_bucket\n  FROM trade_sizes\n  WHERE timestamp >= UNIX_TIMESTAMP($__timeFrom()) * 1000 AND timestamp <= UNIX_TIMESTAMP($__timeTo()) * 1000\n    AND ('${pair:raw}' = '$__all' OR pair IN (${pair:sqlstring}))\n)\nSELECT \n  percentile_bucket as Percentile,\n  pair as Currency,\n  ROUND(AVG(notional_usd), 2) as NotionalUSD\nFROM ranked\nGROUP BY percentile_bucket, pair\nORDER BY \n  CASE percentile_bucket\n    WHEN 'P0-10' THEN 1\n    WHEN 'P10-25' THEN 2\n    WHEN 'P25-50' THEN 3\n    WHEN 'P50-75' THEN 4\n    WHEN 'P75-90' THEN 5\n    WHEN 'P90-100' THEN 6\n  END, pair",
          "refId": "A"
        }
      ],
      "title": "Notional USD by Percentile (by Currency)",
      "transformations": [
        {
          "id": "prepareTimeSeries",
          "options": {
            "format": "multi"
          }
        }
