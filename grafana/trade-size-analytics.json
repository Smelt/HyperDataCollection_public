          "rawSql": "WITH ranked AS (\n  SELECT \n    pair,\n    notional_usd,\n    PERCENT_RANK() OVER (PARTITION BY pair ORDER BY notional_usd) as pct_rank\n  FROM trade_sizes\n  WHERE timestamp >= UNIX_TIMESTAMP($__timeFrom()) * 1000 AND timestamp <= UNIX_TIMESTAMP($__timeTo()) * 1000\n    AND ('${pair:raw}' = '$__all' OR pair IN (${pair:sqlstring}))\n)\nSELECT \n  pair as Currency,\n  ROUND(MIN(CASE WHEN pct_rank >= 0.25 THEN notional_usd END), 2) as P25_USD,\n  ROUND(MIN(CASE WHEN pct_rank >= 0.50 THEN notional_usd END), 2) as P50_USD,\n  COUNT(*) as Samples\nFROM ranked\nGROUP BY pair\nHAVING COUNT(*) >= 3\nORDER BY P25_USD DESC",
