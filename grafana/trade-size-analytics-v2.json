          "rawSql": "WITH ranked AS (SELECT pair, notional_usd, PERCENT_RANK() OVER (PARTITION BY pair ORDER BY notional_usd) as pct FROM trade_sizes WHERE timestamp >= UNIX_TIMESTAMP($__timeFrom()) * 1000 AND timestamp <= UNIX_TIMESTAMP($__timeTo()) * 1000 AND ('${pair:raw}' = '$__all' OR pair IN (${pair:sqlstring}))) SELECT pair as Currency, COUNT(*) as Trades, ROUND(SUM(notional_usd), 0) as Volume, ROUND(MIN(CASE WHEN pct >= 0.25 THEN notional_usd END), 0) as P25, ROUND(MIN(CASE WHEN pct >= 0.50 THEN notional_usd END), 0) as P50, ROUND(MIN(CASE WHEN pct >= 0.75 THEN notional_usd END), 0) as P75 FROM ranked GROUP BY pair ORDER BY Volume DESC",
