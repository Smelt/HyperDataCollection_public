          "rawSql": "SELECT CASE WHEN notional_usd < 10 THEN '$0-10' WHEN notional_usd < 25 THEN '$10-25' WHEN notional_usd < 50 THEN '$25-50' WHEN notional_usd < 100 THEN '$50-100' WHEN notional_usd < 250 THEN '$100-250' WHEN notional_usd < 500 THEN '$250-500' WHEN notional_usd < 1000 THEN '$500-1K' WHEN notional_usd < 5000 THEN '$1K-5K' WHEN notional_usd < 10000 THEN '$5K-10K' ELSE '$10K+' END as size_bucket, COUNT(*) as trades FROM trade_sizes WHERE timestamp >= UNIX_TIMESTAMP($__timeFrom()) * 1000 AND timestamp <= UNIX_TIMESTAMP($__timeTo()) * 1000 AND ('${pair:raw}' = '$__all' OR pair IN (${pair:sqlstring})) GROUP BY size_bucket ORDER BY CASE size_bucket WHEN '$0-10' THEN 1 WHEN '$10-25' THEN 2 WHEN '$25-50' THEN 3 WHEN '$50-100' THEN 4 WHEN '$100-250' THEN 5 WHEN '$250-500' THEN 6 WHEN '$500-1K' THEN 7 WHEN '$1K-5K' THEN 8 WHEN '$5K-10K' THEN 9 ELSE 10 END",
