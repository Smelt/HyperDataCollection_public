          "rawSql": "SELECT FROM_UNIXTIME(FLOOR(timestamp/1000/$interval)*$interval) as time, 'Buy Volume' as metric, ROUND(SUM(CASE WHEN side = 'B' THEN notional_usd ELSE 0 END), 2) as value FROM trade_sizes WHERE timestamp >= UNIX_TIMESTAMP($__timeFrom()) * 1000 AND timestamp <= UNIX_TIMESTAMP($__timeTo()) * 1000 AND ('${pair:raw}' = '$__all' OR pair IN (${pair:sqlstring})) GROUP BY FLOOR(timestamp/1000/$interval) UNION ALL SELECT FROM_UNIXTIME(FLOOR(timestamp/1000/$interval)*$interval) as time, 'Sell Volume' as metric, ROUND(SUM(CASE WHEN side = 'A' THEN notional_usd ELSE 0 END), 2) as value FROM trade_sizes WHERE timestamp >= UNIX_TIMESTAMP($__timeFrom()) * 1000 AND timestamp <= UNIX_TIMESTAMP($__timeTo()) * 1000 AND ('${pair:raw}' = '$__all' OR pair IN (${pair:sqlstring})) GROUP BY FLOOR(timestamp/1000/$interval) ORDER BY time, metric",
