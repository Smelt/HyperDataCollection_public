          },
          "format": "table",
          "rawSql": "SELECT \n  size_bucket as Size_Bucket,\n  ROUND(100.0 * SUM(did_revert_5m) / NULLIF(COUNT(CASE WHEN price_end_5m IS NOT NULL THEN 1 END), 0), 1) as Reversion_Rate\nFROM hype_reversion_analysis\nGROUP BY size_bucket\nORDER BY \n  CASE size_bucket \n    WHEN '201-300' THEN 1 \n    WHEN '300-500' THEN 2 \n    WHEN '500-1000' THEN 3 \n    WHEN '1000+' THEN 4 \n  END",
          "refId": "A"
        }
