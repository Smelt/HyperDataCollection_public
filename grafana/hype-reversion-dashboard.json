          },
          "format": "table",
          "rawSql": "SELECT \n  CASE side WHEN 'B' THEN 'BUY (taker)' ELSE 'SELL (taker)' END as Side,\n  COUNT(*) as Events,\n  ROUND(AVG(total_size), 0) as Avg_Size,\n  ROUND(100.0 * SUM(did_revert_5m) / NULLIF(COUNT(CASE WHEN price_end_5m IS NOT NULL THEN 1 END), 0), 1) as Reversion_Pct,\n  ROUND(AVG(change_5m_bps), 2) as Avg_Change_bps,\n  CASE side WHEN 'B' THEN 'Price drops after' ELSE 'Price rises after' END as Expected_Reversion\nFROM hype_reversion_analysis\nGROUP BY side\nORDER BY side",
          "refId": "A"
        }
      ],
      "title": "Reversion by Side (Buy vs Sell Takers)",
      "type": "table"
    },
