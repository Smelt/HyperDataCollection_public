      "targets": [
        {
          "datasource": {
            "type": "mysql",
            "uid": "ef1n1ggi71xq8d"
          },
          "format": "table",
          "rawSql": "SELECT \n  FROM_UNIXTIME(timestamp/1000) as Time,\n  CASE side WHEN 'B' THEN 'BUY' ELSE 'SELL' END as Side,\n  ROUND(total_size, 0) as Size_HYPE,\n  ROUND(exec_price, 4) as Exec_Price,\n  ROUND(price_end_5m, 4) as Price_5min_Later,\n  change_5m_bps as Change_bps,\n  CASE did_revert_5m WHEN 1 THEN 'YES' ELSE 'NO' END as Reverted,\n  CASE \n    WHEN did_revert_5m = 1 THEN CONCAT('+', ABS(change_5m_bps), ' bps')\n    WHEN price_end_5m IS NULL THEN 'No data'\n    ELSE CONCAT('-', ABS(change_5m_bps), ' bps')\n  END as PnL_if_Faded\nFROM hype_reversion_analysis\nWHERE price_end_5m IS NOT NULL\nORDER BY timestamp DESC\nLIMIT 50",
          "refId": "A"
        }
      ],
      "title": "Recent Large Orders (Last 50)",
      "type": "table"
    },
    {
      "gridPos": {
        "h": 5,
