      "targets": [
        {
          "datasource": {
            "type": "mysql",
            "uid": "ef1n1ggi71xq8d"
          },
          "format": "table",
          "rawSql": "SELECT \n  CASE side WHEN 'B' THEN 'BUY' ELSE 'SELL' END as Side,\n  size_bucket as Size_Bucket,\n  COUNT(*) as Events,\n  ROUND(AVG(total_size), 0) as Avg_Size_HYPE,\n  ROUND(100.0 * SUM(did_revert_5m) / NULLIF(COUNT(CASE WHEN price_end_5m IS NOT NULL THEN 1 END), 0), 1) as Reversion_Pct,\n  ROUND(AVG(CASE WHEN did_revert_5m = 1 THEN ABS(change_5m_bps) END), 2) as Avg_Profit_bps,\n  ROUND(AVG(CASE WHEN did_revert_5m = 0 AND price_end_5m IS NOT NULL THEN ABS(change_5m_bps) END), 2) as Avg_Loss_bps,\n  ROUND(\n    (AVG(CASE WHEN did_revert_5m = 1 THEN ABS(change_5m_bps) END) * SUM(did_revert_5m) - \n     AVG(CASE WHEN did_revert_5m = 0 AND price_end_5m IS NOT NULL THEN ABS(change_5m_bps) END) * \n     SUM(CASE WHEN did_revert_5m = 0 AND price_end_5m IS NOT NULL THEN 1 ELSE 0 END)) / \n    NULLIF(COUNT(CASE WHEN price_end_5m IS NOT NULL THEN 1 END), 0), 2\n  ) as Expected_Value_bps\nFROM hype_reversion_analysis\nGROUP BY side, size_bucket\nORDER BY side, \n  CASE size_bucket \n    WHEN '201-300' THEN 1 \n    WHEN '300-500' THEN 2 \n    WHEN '500-1000' THEN 3 \n    WHEN '1000+' THEN 4 \n  END",
          "refId": "A"
        }
      ],
