      "targets": [
        {
          "datasource": {
            "type": "mysql",
            "uid": "ef1n1ggi71xq8d"
          },
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "WITH position_pairs AS (\n  SELECT\n    coin,\n    time as close_time,\n    dir,\n    LAG(time) OVER (PARTITION BY coin ORDER BY time) as open_time,\n    LAG(dir) OVER (PARTITION BY coin ORDER BY time) as prev_dir\n  FROM user_trades\n  WHERE time >= UNIX_TIMESTAMP($__timeFrom()) * 1000\n    AND time <= UNIX_TIMESTAMP($__timeTo()) * 1000\n    AND ('${exclude_currency:raw}' = '$__all' OR coin NOT IN (${exclude_currency:sqlstring}))\n),\nclosed_positions AS (\n  SELECT\n    (close_time - open_time) / 1000 as hold_duration_seconds\n  FROM position_pairs\n  WHERE dir LIKE 'Close%'\n    AND prev_dir LIKE 'Open%'\n    AND open_time IS NOT NULL\n)\nSELECT AVG(hold_duration_seconds) as value FROM closed_positions",
          "refId": "A"
        }
      ],
      "title": "Avg Hold Time",
      "type": "stat"
    },
