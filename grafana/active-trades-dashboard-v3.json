          "id": "organize",
          "options": {
            "excludeByName": {
              "Positions": false
            },
            "indexByName": {
              "Avg Profit": 1,
              "Percentile": 0,
              "Positions": 2
            },
            "renameByName": {}
          }
        }
      ],
      "type": "barchart"
