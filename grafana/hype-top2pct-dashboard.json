        {
          "datasource": {
            "type": "mysql",
            "uid": "ef1n1ggi71xq8d"
          },
          "format": "table",
          "rawSql": "SELECT \n  FROM_UNIXTIME(event_end_ts/1000) as Time,\n  CASE side WHEN 'B' THEN 'BUY' ELSE 'SELL' END as Taker,\n  ROUND(total_size, 0) as Size_HYPE,\n  ROUND(exec_price, 4) as Exec_Price,\n  ROUND(next_trade_price, 4) as Next_Trade,\n  impact_bps as Impact_bps,\n  secs_to_next_trade as Secs_to_Next,\n  ROUND(price_end_1m, 4) as Price_1min,\n  change_1m_bps as Change_1m_bps,\n  CASE did_revert_1m WHEN 1 THEN 'WIN' WHEN 0 THEN 'LOSS' ELSE '--' END as Fade_Result\nFROM hype_top2pct_analysis\nORDER BY event_end_ts DESC\nLIMIT 30",
          "refId": "A"
        }
