      "targets": [
        {
          "datasource": {
            "type": "mysql",
            "uid": "ef1n1ggi71xq8d"
          },
          "format": "table",
          "rawSql": "SELECT \n  CASE side WHEN 'B' THEN 'Fade BUY takers' ELSE 'Fade SELL takers' END as Strategy,\n  SUM(CASE WHEN price_end_1m IS NOT NULL THEN 1 ELSE 0 END) as Events,\n  ROUND(AVG(total_size), 0) as Avg_Size,\n  ROUND(AVG(impact_bps), 2) as Immediate_Impact_bps,\n  ROUND(100.0 * SUM(did_revert_1m) / NULLIF(SUM(CASE WHEN did_revert_1m IS NOT NULL THEN 1 END), 0), 1) as Win_Rate_Pct,\n  ROUND(AVG(CASE WHEN did_revert_1m = 1 THEN ABS(change_1m_bps) END), 2) as Avg_Win_bps,\n  ROUND(AVG(CASE WHEN did_revert_1m = 0 THEN ABS(change_1m_bps) END), 2) as Avg_Loss_bps,\n  ROUND(\n    (SUM(did_revert_1m) / NULLIF(SUM(CASE WHEN did_revert_1m IS NOT NULL THEN 1 END), 0)) * \n    AVG(CASE WHEN did_revert_1m = 1 THEN ABS(change_1m_bps) END) -\n    (1 - SUM(did_revert_1m) / NULLIF(SUM(CASE WHEN did_revert_1m IS NOT NULL THEN 1 END), 0)) *\n    AVG(CASE WHEN did_revert_1m = 0 THEN ABS(change_1m_bps) END)\n  , 2) as Expected_Value_bps\nFROM hype_top2pct_analysis\nGROUP BY side\nORDER BY side DESC",
          "refId": "A"
        }
      ],
      "title": "1-Minute Reversion Analysis by Side",
      "type": "table"
    },
