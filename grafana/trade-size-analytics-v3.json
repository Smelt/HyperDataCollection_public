          "format": "table",
          "rawQuery": true,
          "rawSql": "WITH orders AS (SELECT buyer, pair, side, FLOOR(timestamp/1000) as order_sec, MIN(timestamp) as first_fill, COUNT(*) as fills, SUM(notional_usd) as order_usd, GROUP_CONCAT(ROUND(notional_usd, 0) ORDER BY timestamp SEPARATOR ' + ') as fill_breakdown FROM trade_sizes WHERE timestamp >= UNIX_TIMESTAMP($__timeFrom()) * 1000 AND timestamp <= UNIX_TIMESTAMP($__timeTo()) * 1000 AND buyer IS NOT NULL AND ('${pair:raw}' = '$__all' OR pair IN (${pair:sqlstring})) GROUP BY buyer, pair, side, FLOOR(timestamp/1000) HAVING COUNT(*) >= 2) SELECT FROM_UNIXTIME(first_fill/1000) as Time, pair as Pair, CASE WHEN side = 'B' THEN 'BUY' ELSE 'SELL' END as Side, fills as Fills, CONCAT('$', fill_breakdown) as FillBreakdown, ROUND(order_usd, 0) as TotalUSD, CONCAT(LEFT(buyer, 6), '...', RIGHT(buyer, 4)) as Buyer FROM orders ORDER BY first_fill DESC LIMIT 50",
