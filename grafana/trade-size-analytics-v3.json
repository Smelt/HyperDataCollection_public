      "pluginVersion": "12.2.0",
      "targets": [
        {
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "\n  WITH orders AS (\n    SELECT\n      buyer,\n      pair,\n      side,\n      FLOOR(timestamp/1000) as sec,\n      SUM(notional_usd) as order_usd\n    FROM trade_sizes\n    WHERE timestamp >= UNIX_TIMESTAMP($__timeFrom()) * 1000\n      AND timestamp <= UNIX_TIMESTAMP($__timeTo()) * 1000\n      AND buyer IS NOT NULL\n      AND ('${pair:raw}' = '$__all' OR pair IN (${pair:sqlstring}))\n    GROUP BY buyer, pair, side, FLOOR(timestamp/1000)\n  ),\n  ranked AS (\n    SELECT\n      order_usd,\n      PERCENT_RANK() OVER (ORDER BY order_usd) as pct_rank\n    FROM orders\n  )\n  SELECT\n    'P10' as percentile, ROUND(MIN(order_usd), 2) as value FROM ranked WHERE pct_rank >= 0.10\n  UNION ALL\n  SELECT 'P25', ROUND(MIN(order_usd), 2) FROM ranked WHERE pct_rank >= 0.25\n  UNION ALL\n  SELECT 'P50 (Median)', ROUND(MIN(order_usd), 2) FROM ranked WHERE pct_rank >= 0.50\n  UNION ALL\n  SELECT 'P75', ROUND(MIN(order_usd), 2) FROM ranked WHERE pct_rank >= 0.75\n  UNION ALL\n  SELECT 'P90', ROUND(MIN(order_usd), 2) FROM ranked WHERE pct_rank >= 0.90\n  UNION ALL\n  SELECT 'P95', ROUND(MIN(order_usd), 2) FROM ranked WHERE pct_rank >= 0.95\n  UNION ALL\n  SELECT 'P99', ROUND(MIN(order_usd), 2) FROM ranked WHERE pct_rank >= 0.99\n  ORDER BY FIELD(percentile, 'P10', 'P25', 'P50 (Median)', 'P75', 'P90', 'P95', 'P99')",
          "refId": "A",
          "sql": {
            "columns": [
              {
                "parameters": [],
                "type": "function"
              }
            ],
            "groupBy": [
              {
                "property": {
                  "type": "string"
                },
                "type": "groupBy"
              }
            ],
            "limit": 50
          }
        }
      ],
      "title": "Reconstructed Order Size Distribution",
      "type": "barchart"
    },
