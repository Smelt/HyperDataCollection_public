      "targets": [
        {
          "format": "table",
          "rawQuery": true,
          "rawSql": "WITH orders AS (SELECT buyer, pair, side, MIN(timestamp) as first_fill, MAX(timestamp) as last_fill, COUNT(*) as fills, SUM(notional_usd) as order_usd, SUM(size) as total_size FROM trade_sizes WHERE timestamp >= UNIX_TIMESTAMP($__timeFrom()) * 1000 AND timestamp <= UNIX_TIMESTAMP($__timeTo()) * 1000 AND buyer IS NOT NULL AND ('${pair:raw}' = '$__all' OR pair IN (${pair:sqlstring})) GROUP BY buyer, pair, side, FLOOR(timestamp/1000) HAVING SUM(notional_usd) >= 1000) SELECT FROM_UNIXTIME(first_fill/1000) as Time, pair as Pair, CASE WHEN side = 'B' THEN 'BUY' ELSE 'SELL' END as Side, fills as Fills, ROUND(order_usd, 0) as OrderUSD, ROUND(total_size, 2) as Size, CONCAT(LEFT(buyer, 6), '...', RIGHT(buyer, 4)) as Buyer FROM orders ORDER BY first_fill DESC LIMIT 30",
          "refId": "A"
        }
      ],
      "title": "Recent Large Orders (>$1K)",
      "type": "table"
    },
