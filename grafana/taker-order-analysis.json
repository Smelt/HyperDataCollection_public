      "targets": [
        {
          "format": "table",
          "rawQuery": true,
          "rawSql": "WITH orders AS (SELECT buyer, pair, side, FLOOR(timestamp/1000) as sec, COUNT(*) as fills, SUM(notional_usd) as order_usd, MIN(price) as min_px, MAX(price) as max_px FROM trade_sizes WHERE timestamp >= UNIX_TIMESTAMP($__timeFrom()) * 1000 AND timestamp <= UNIX_TIMESTAMP($__timeTo()) * 1000 AND buyer IS NOT NULL AND ('${pair:raw}' = '$__all' OR pair IN (${pair:sqlstring})) GROUP BY buyer, pair, side, FLOOR(timestamp/1000)) SELECT pair as Currency, COUNT(*) as Orders, SUM(CASE WHEN fills > 1 THEN 1 ELSE 0 END) as MultiFill, ROUND(SUM(CASE WHEN fills > 1 THEN 1 ELSE 0 END) / COUNT(*) * 100, 0) as PctMulti, ROUND(AVG(order_usd), 0) as AvgOrder, ROUND(MAX(order_usd), 0) as MaxOrder, ROUND(AVG(fills), 1) as AvgFills, ROUND(AVG(CASE WHEN fills > 1 THEN (max_px - min_px) / min_px * 100 END), 3) as AvgImpact FROM orders GROUP BY pair ORDER BY AvgOrder DESC",
