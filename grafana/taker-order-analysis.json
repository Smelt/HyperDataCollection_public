      "targets": [
        {
          "format": "table",
          "rawQuery": true,
          "rawSql": "WITH orders AS (SELECT buyer, pair, side, FLOOR(timestamp/1000) as sec, COUNT(*) as fills, SUM(notional_usd) as order_usd, MIN(price) as min_px, MAX(price) as max_px FROM trade_sizes WHERE timestamp >= UNIX_TIMESTAMP($__timeFrom()) * 1000 AND timestamp <= UNIX_TIMESTAMP($__timeTo()) * 1000 AND buyer IS NOT NULL AND ('${pair:raw}' = '$__all' OR pair IN (${pair:sqlstring})) GROUP BY buyer, pair, side, FLOOR(timestamp/1000)), buckets AS (SELECT CASE WHEN order_usd < 100 THEN '1. <$100' WHEN order_usd < 500 THEN '2. $100-500' WHEN order_usd < 1000 THEN '3. $500-1K' WHEN order_usd < 2500 THEN '4. $1K-2.5K' WHEN order_usd < 5000 THEN '5. $2.5K-5K' WHEN order_usd < 10000 THEN '6. $5K-10K' ELSE '7. $10K+' END as bucket, fills, order_usd, CASE WHEN fills > 1 THEN (max_px - min_px) / min_px * 100 ELSE 0 END as impact_pct FROM orders) SELECT SUBSTRING(bucket, 4) as OrderSize, COUNT(*) as Orders, ROUND(AVG(fills), 1) as AvgFills, SUM(CASE WHEN fills > 1 THEN 1 ELSE 0 END) as WalkedBook, ROUND(AVG(CASE WHEN fills > 1 THEN impact_pct END), 4) as AvgImpact, ROUND(MAX(impact_pct), 4) as MaxImpact FROM buckets GROUP BY bucket ORDER BY bucket",
          "refId": "A"
        }
      ],
      "title": "Price Impact by Order Size",
      "type": "table"
