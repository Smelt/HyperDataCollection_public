      "targets": [
        {
          "format": "table",
          "rawQuery": true,
          "rawSql": "WITH orders AS (SELECT buyer, pair, side, FLOOR(timestamp/1000) as sec, SUM(notional_usd) as order_usd FROM trade_sizes WHERE timestamp >= UNIX_TIMESTAMP($__timeFrom()) * 1000 AND timestamp <= UNIX_TIMESTAMP($__timeTo()) * 1000 AND buyer IS NOT NULL AND ('${pair:raw}' = '$__all' OR pair IN (${pair:sqlstring})) GROUP BY buyer, pair, side, FLOOR(timestamp/1000)), buckets AS (SELECT CASE WHEN order_usd < 25 THEN '01. <$25' WHEN order_usd < 50 THEN '02. $25-50' WHEN order_usd < 100 THEN '03. $50-100' WHEN order_usd < 250 THEN '04. $100-250' WHEN order_usd < 500 THEN '05. $250-500' WHEN order_usd < 1000 THEN '06. $500-1K' WHEN order_usd < 2500 THEN '07. $1K-2.5K' WHEN order_usd < 5000 THEN '08. $2.5K-5K' WHEN order_usd < 10000 THEN '09. $5K-10K' WHEN order_usd < 25000 THEN '10. $10K-25K' ELSE '11. $25K+' END as bucket, order_usd FROM orders) SELECT SUBSTRING(bucket, 5) as Size, COUNT(*) as Orders FROM buckets GROUP BY bucket ORDER BY bucket",
