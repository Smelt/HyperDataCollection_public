      "targets": [
        {
          "format": "table",
          "rawQuery": true,
          "rawSql": "WITH orders AS (SELECT buyer, pair, side, FLOOR(timestamp/1000) as sec, COUNT(*) as fills, MIN(price) as min_px, MAX(price) as max_px, (MAX(price) - MIN(price)) / MIN(price) * 100 as impact_pct FROM trade_sizes WHERE timestamp >= UNIX_TIMESTAMP($__timeFrom()) * 1000 AND timestamp <= UNIX_TIMESTAMP($__timeTo()) * 1000 AND buyer IS NOT NULL AND ('${pair:raw}' = '$__all' OR pair IN (${pair:sqlstring})) GROUP BY buyer, pair, side, FLOOR(timestamp/1000) HAVING COUNT(*) > 1), buckets AS (SELECT CASE WHEN impact_pct < 0.01 THEN '01. <0.01%' WHEN impact_pct < 0.02 THEN '02. 0.01-0.02%' WHEN impact_pct < 0.05 THEN '03. 0.02-0.05%' WHEN impact_pct < 0.1 THEN '04. 0.05-0.1%' WHEN impact_pct < 0.2 THEN '05. 0.1-0.2%' WHEN impact_pct < 0.5 THEN '06. 0.2-0.5%' WHEN impact_pct < 1.0 THEN '07. 0.5-1%' ELSE '08. >1%' END as bucket, impact_pct FROM orders) SELECT SUBSTRING(bucket, 5) as Impact, COUNT(*) as Orders FROM buckets GROUP BY bucket ORDER BY bucket",
          "refId": "A"
        }
      ],
      "title": "Price Impact Distribution (Histogram)",
      "type": "histogram"
