        {
          "format": "table",
          "rawQuery": true,
          "rawSql": "WITH orders AS (SELECT buyer, pair, side, FLOOR(timestamp/1000) as sec, MIN(timestamp) as first_fill, COUNT(*) as fills, SUM(notional_usd) as order_usd, SUM(size) as total_size, MIN(price) as entry_px, MAX(price) as exit_px, (MAX(price) - MIN(price)) / MIN(price) * 100 as impact_pct FROM trade_sizes WHERE timestamp >= UNIX_TIMESTAMP($__timeFrom()) * 1000 AND timestamp <= UNIX_TIMESTAMP($__timeTo()) * 1000 AND buyer IS NOT NULL AND ('${pair:raw}' = '$__all' OR pair IN (${pair:sqlstring})) GROUP BY buyer, pair, side, FLOOR(timestamp/1000) HAVING SUM(notional_usd) >= 1000 AND COUNT(*) > 1) SELECT FROM_UNIXTIME(first_fill/1000) as Time, pair as Pair, CASE WHEN side = 'B' THEN 'BUY' ELSE 'SELL' END as Side, fills as Fills, ROUND(order_usd, 0) as OrderUSD, ROUND(entry_px, 6) as EntryPx, ROUND(exit_px, 6) as ExitPx, ROUND(impact_pct, 4) as ImpactPct, CONCAT(LEFT(buyer, 6), '...') as Trader FROM orders ORDER BY first_fill DESC LIMIT 50",
          "refId": "A"
        }
      ],
      "title": "Large Taker Orders (>$1K with slippage)",
      "type": "table"
