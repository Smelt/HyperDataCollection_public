          },
          "format": "table",
          "rawSql": "SELECT pair, AVG(avg_spread_bps) as avg_spread_bps, AVG(avg_spread_bps)/100 as avg_spread_pct, (AVG(avg_spread_bps) - 3.0) as profit_bps, STDDEV(avg_spread_bps)/100 as volatility, MIN(min_spread_bps)/100 as min_spread, MAX(max_spread_bps)/100 as max_spread, SUM(sample_count) as samples, AVG(avg_bid_size + avg_ask_size) as avg_liquidity FROM spread_snapshots_1min WHERE timestamp >= $__timeFrom() AND timestamp <= $__timeTo() GROUP BY pair HAVING avg_spread_bps > 3.0 ORDER BY profit_bps DESC LIMIT 30",
          "refId": "A"
        }
      ],
      "title": "Best Opportunities After Fees (1.5 bps maker fee)",
