# Hyperliquid API Configuration
HYPERLIQUID_API_URL=https://api.hyperliquid.xyz
HYPERLIQUID_WS_URL=wss://api.hyperliquid.xyz/ws

# Database Configuration
DB_HOST=your-database-host.example.com
DB_PORT=3306
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_NAME=your_db_name

# Monitoring Configuration
SNAPSHOT_INTERVAL_MS=10000
PAIRS=all
# To monitor specific pairs instead, use: PAIRS=REZ,SOL,BTC,ETH,ATOM
LOG_LEVEL=info

# Smart Filtering (Only track profitable pairs)
ENABLE_SMART_FILTERING=true
MIN_PROFIT_BPS=10
MAX_PAIRS=20
SCAN_INTERVAL_HOURS=24

# HIP-3 Builder Dexes (tokenized stocks, pre-IPO perps, etc.)
# Comma-separated list of dex names to include in pair discovery
HIP3_DEXES=vntl,xyz

# Data Storage
DATA_DIR=./data
ENABLE_CSV_LOGGING=true
ENABLE_JSON_SUMMARY=true
ENABLE_DB_LOGGING=true

# Data Collection & Statistics
STATS_CALCULATION_INTERVAL_MS=3600000
CLEANUP_INTERVAL_HOURS=24

# Backup Configuration
BACKUP_DIR=./backups
BACKUP_ENABLED=true

# Fee Configuration (for profitability calculations)
MAKER_FEE_BPS=1.5
TAKER_FEE_BPS=4.5

# Hyperliquid Wallet Configuration (KEEP PRIVATE!)
# Main wallet (holds funds)
MAIN_WALLET_ADDRESS=0xYOUR_MAIN_WALLET_ADDRESS
# API wallet (authorized to trade on behalf of main wallet)
API_WALLET_ADDRESS=0xYOUR_API_WALLET_ADDRESS
API_WALLET_PRIVATE_KEY=your_api_wallet_private_key
# Legacy (kept for backwards compatibility)
WALLET_ADDRESS=0xYOUR_API_WALLET_ADDRESS
WALLET_PRIVATE_KEY=your_api_wallet_private_key

# Monitoring
ENABLE_PERFORMANCE_LOGS=false

# AWS Configuration (for CloudWatch metrics, optional)
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
AWS_REGION=ap-northeast-1
